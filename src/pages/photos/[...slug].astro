---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Location from "~icons/carbon/location-filled";

export async function getStaticPaths() {
    const photos = await getCollection("photos");
    return photos.map((photo) => ({
        params: { slug: photo.id },
        props: photo,
    }));
}

type Props = CollectionEntry<"photos">;
const entry = Astro.props;

function formatFullDate(d: Date): string {
    return d.toLocaleDateString("en-US", {
        month: "long",
        day: "numeric",
        year: "numeric",
    });
}

const dateText = entry.data.endDate
    ? `${formatFullDate(entry.data.startDate)} - ${formatFullDate(entry.data.endDate)}`
    : formatFullDate(entry.data.startDate);

type LightboxEntry = { alt: string; id: string };
const lightboxData: LightboxEntry[] = [];

if (entry.data.sections) {
    entry.data.sections.forEach((section, si) => {
        section.photos.forEach((photo, pi) => {
            lightboxData.push({ alt: photo.alt || "", id: `${si}-${pi}` });
        });
    });
} else if (entry.data.photos) {
    entry.data.photos.forEach((_photo, i) => {
        lightboxData.push({ alt: _photo.alt || "", id: `${i}` });
    });
}
---

<BaseLayout pageTitle={`Photos - ${entry.data.title}`}>
    <div class="flex flex-col">
        <div
            class="flex flex-col w-full border items-start bg-secondary-bg border-line"
        >
            <h1
                class="font-crimson italic text-3xl text-ink border-b border-line w-full p-2"
            >
                {entry.data.title}
            </h1>
            <div
                class="font-mono text-xs text-ink self-end p-2 border-l border-line"
            >
                {dateText}
            </div>
            <div
                class="font-crimson text-ink p-2 w-full border-t border-line text-lg"
            >
                {entry.data.description}
            </div>
        </div>

        {
            entry.data.sections ? (
                <div class="flex flex-col gap-4">
                    {entry.data.sections.map((section, si) => (
                        <div class="border border-line hard-shadow">
                            <div class="flex flex-row border-b border-line items-center bg-secondary-bg">
                                <div class="font-mono font-bold text-xs px-2 py-2">
                                    {section.title}
                                </div>
                            </div>
                            <div class="columns-2 gap-0">
                                {section.photos.map((photo, pi) => (
                                    <div
                                        data-lightbox={`${si}-${pi}`}
                                        class="break-inside-avoid cursor-pointer"
                                    >
                                        <Image
                                            src={photo.src}
                                            alt={photo.alt || ""}
                                            loading="lazy"
                                            class="block w-full h-auto"
                                        />
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            ) : entry.data.photos ? (
                <div class="grid grid-cols-1 md:grid-cols-3 diagonal-lines border-l border-r border-b border-line bg-secondary-bg hard-shadow">
                    {entry.data.photos.map((photo, i) => (
                        <div
                            data-lightbox={`${i}`}
                            class="aspect-square cursor-pointer"
                        >
                            <Image
                                src={photo.src}
                                alt={photo.alt || ""}
                                loading="lazy"
                                class="block w-full h-full object-cover"
                            />
                        </div>
                    ))}
                </div>
            ) : null
        }
    </div>

    <div
        id="lightbox"
        class="fixed inset-0 z-50 hidden"
        role="dialog"
        aria-modal="true"
    >
        <div id="lightbox-backdrop" class="absolute inset-0 bg-black/90"></div>

        <div
            class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none"
        >
            <img
                id="lightbox-img"
                alt=""
                class="block max-w-[90vw] max-h-[85vh] object-contain border border-line pointer-events-auto"
            />
        </div>

        <div
            id="lightbox-chrome"
            class="absolute inset-0 pointer-events-none font-mono text-xs text-white"
        >
            <button
                id="lightbox-close"
                aria-label="Close"
                class="pointer-events-auto absolute top-4 right-4 border border-line px-3 py-1.5 bg-black/40 hover:bg-white hover:text-black transition-colors"
            >
                close <span class="text-white/50">[esc]</span>
            </button>
            <button
                id="lightbox-prev"
                aria-label="Previous"
                class="pointer-events-auto absolute left-4 top-1/2 -translate-y-1/2 border border-line w-10 h-10 flex items-center justify-center bg-black/40 hover:bg-white hover:text-black transition-colors disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:bg-black/40 disabled:hover:text-white"
            >
                &larr;
            </button>
            <button
                id="lightbox-next"
                aria-label="Next"
                class="pointer-events-auto absolute right-4 top-1/2 -translate-y-1/2 border border-line w-10 h-10 flex items-center justify-center bg-black/40 hover:bg-white hover:text-black transition-colors disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:bg-black/40 disabled:hover:text-white"
            >
                &rarr;
            </button>
            <div
                class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col gap-1 items-center max-w-[90vw] text-center"
            >
                <p
                    id="lightbox-alt"
                    class="border border-line bg-black/40 px-2 py-1 empty:hidden"
                >
                </p>
                <p id="lightbox-counter" class="text-white/60"></p>
            </div>
        </div>
    </div>
</BaseLayout>

<script define:vars={{ lightboxData }}>
    const ANIMATION_MS = 280;
    const CHROME_FADE_MS = 180;
    const CHROME_OUT_MS = 120;
    const EASE = "cubic-bezier(0.22, 1, 0.36, 1)";

    const lightbox = document.getElementById("lightbox");
    const backdrop = document.getElementById("lightbox-backdrop");
    const chrome = document.getElementById("lightbox-chrome");
    const lightboxImg = document.getElementById("lightbox-img");
    const lightboxAlt = document.getElementById("lightbox-alt");
    const lightboxCounter = document.getElementById("lightbox-counter");
    const btnClose = document.getElementById("lightbox-close");
    const btnPrev = document.getElementById("lightbox-prev");
    const btnNext = document.getElementById("lightbox-next");

    let currentIndex = -1;
    let currentThumb = null;
    let isAnimating = false;

    const wait = (ms) => new Promise((r) => setTimeout(r, ms));

    function getThumb(id) {
        return document.querySelector(`[data-lightbox="${id}"]`);
    }

    function thumbSrc(thumb) {
        return thumb?.querySelector("img")?.src ?? "";
    }

    async function ensureLoaded(img) {
        try {
            await img.decode();
        } catch {}
    }

    // FLIP: transform that visually places `target` element at `from` rect.
    // Uses transform-origin: top left, so identity transform = element at its layout position.
    function flipTransform(from, to) {
        const dx = from.left - to.left;
        const dy = from.top - to.top;
        const sx = from.width / to.width;
        const sy = from.height / to.height;
        return `translate(${dx}px, ${dy}px) scale(${sx}, ${sy})`;
    }

    function updateInfo(idx) {
        const entry = lightboxData[idx];
        lightboxAlt.textContent = entry.alt;
        lightboxCounter.textContent = `${idx + 1} / ${lightboxData.length}`;
        btnPrev.disabled = idx === 0;
        btnNext.disabled = idx === lightboxData.length - 1;
    }

    async function open(id) {
        if (isAnimating) return;
        const idx = lightboxData.findIndex((p) => p.id === id);
        if (idx === -1) return;
        const thumb = getThumb(id);
        if (!thumb) return;

        isAnimating = true;
        currentIndex = idx;
        currentThumb = thumb;

        lightboxImg.src = thumbSrc(thumb);
        lightboxImg.alt = lightboxData[idx].alt;
        updateInfo(idx);

        // Reveal lightbox; image hidden until we've positioned it at the thumb.
        lightbox.classList.remove("hidden");
        // Reserve scrollbar space so toggling overflow doesn't reflow the page.
        const scrollbarW =
            window.innerWidth - document.documentElement.clientWidth;
        if (scrollbarW > 0) {
            document.body.style.paddingRight = `${scrollbarW}px`;
        }
        document.body.style.overflow = "hidden";
        backdrop.style.transition = "none";
        backdrop.style.opacity = "0";
        chrome.style.transition = "none";
        chrome.style.opacity = "0";
        lightboxImg.style.opacity = "0";
        lightboxImg.style.transition = "none";

        await ensureLoaded(lightboxImg);

        const thumbRect = thumb.getBoundingClientRect();
        const targetRect = lightboxImg.getBoundingClientRect();

        // Place image at thumb position via inverse transform.
        lightboxImg.style.transformOrigin = "top left";
        lightboxImg.style.transform = flipTransform(thumbRect, targetRect);

        // Hide thumb just before image becomes visible. Use opacity rather than
        // visibility so the compositor keeps the layer warm — re-showing it on
        // close is then immediate, with no risk of a one-frame paint gap.
        thumb.style.opacity = "0";

        // Force the start state to commit before declaring transitions.
        void lightboxImg.offsetHeight;

        // Reveal and animate to identity. Opacity flips instantly because the
        // transition only covers `transform` — so the image appears at the
        // thumb's spot exactly when the morph begins.
        lightboxImg.style.transition = `transform ${ANIMATION_MS}ms ${EASE}`;
        lightboxImg.style.opacity = "1";
        lightboxImg.style.transform = "";
        backdrop.style.transition = `opacity ${ANIMATION_MS}ms ${EASE}`;
        backdrop.style.opacity = "1";

        await wait(ANIMATION_MS);

        chrome.style.transition = `opacity ${CHROME_FADE_MS}ms ease`;
        chrome.style.opacity = "1";

        isAnimating = false;
    }

    async function close() {
        if (isAnimating) return;
        if (currentIndex === -1 || !currentThumb) return;
        isAnimating = true;

        const thumb = currentThumb;

        chrome.style.transition = `opacity ${CHROME_OUT_MS}ms ease`;
        chrome.style.opacity = "0";
        await wait(CHROME_OUT_MS);

        // Re-measure: window may have resized while open.
        const thumbRect = thumb.getBoundingClientRect();
        const targetRect = lightboxImg.getBoundingClientRect();

        lightboxImg.style.transition = `transform ${ANIMATION_MS}ms ${EASE}`;
        lightboxImg.style.transformOrigin = "top left";
        lightboxImg.style.transform = flipTransform(thumbRect, targetRect);
        backdrop.style.transition = `opacity ${ANIMATION_MS}ms ${EASE}`;
        backdrop.style.opacity = "0";

        await wait(ANIMATION_MS);

        // Reveal the thumb while the lightbox image is still on screen at
        // the same spot, then wait one paint cycle before hiding the lightbox.
        // Without this, there's a one-frame gap where the lightbox image is
        // gone but the thumb hasn't yet been committed to the compositor —
        // visible as a flash of background color.
        thumb.style.opacity = "";
        await new Promise((r) =>
            requestAnimationFrame(() => requestAnimationFrame(r)),
        );

        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
        document.body.style.paddingRight = "";
        lightboxImg.style.transition = "none";
        lightboxImg.style.transform = "";
        lightboxImg.style.opacity = "";
        lightboxImg.removeAttribute("src");
        currentThumb = null;
        currentIndex = -1;

        isAnimating = false;
    }

    function navigate(delta) {
        if (isAnimating) return;
        const newIdx = currentIndex + delta;
        if (newIdx < 0 || newIdx >= lightboxData.length) return;

        // Restore old thumb so it's visible again when the user closes onto
        // a different photo than they opened.
        if (currentThumb) currentThumb.style.opacity = "";

        currentIndex = newIdx;
        const entry = lightboxData[newIdx];
        const newThumb = getThumb(entry.id);

        lightboxImg.src = thumbSrc(newThumb);
        lightboxImg.alt = entry.alt;
        updateInfo(newIdx);

        currentThumb = newThumb;
        if (newThumb) newThumb.style.opacity = "0";
    }

    document.addEventListener("click", (e) => {
        const target = e.target?.closest?.("[data-lightbox]");
        if (target) open(target.dataset.lightbox);
    });

    btnClose.addEventListener("click", close);
    btnPrev.addEventListener("click", () => navigate(-1));
    btnNext.addEventListener("click", () => navigate(1));

    backdrop.addEventListener("click", close);

    document.addEventListener("keydown", (e) => {
        if (currentIndex === -1) return;
        if (e.key === "Escape") close();
        else if (e.key === "ArrowRight") navigate(1);
        else if (e.key === "ArrowLeft") navigate(-1);
    });
</script>
