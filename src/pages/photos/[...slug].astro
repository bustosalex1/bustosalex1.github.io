---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const photos = await getCollection("photos");
    return photos.map((photo) => ({
        params: { slug: photo.id },
        props: photo,
    }));
}

type Props = CollectionEntry<"photos">;
const entry = Astro.props;
---

<BaseLayout pageTitle={`Photos - ${entry.data.title}`}>
    <div class="flex flex-col">
        <div
            class="flex flex-col w-full border items-start bg-secondary-bg border-line"
        >
            <h1
                class="font-crimson italic text-3xl text-ink border-b border-line w-full p-2"
            >
                {entry.data.title}
            </h1>
            <div
                class="font-mono text-xs text-ink self-end p-2 border-l border-line"
            >
                May 21, 2025 - May 22, 2025
            </div>
            <div class="font-crimson text-ink p-2 w-full border-t border-line">
                {entry.data.description}
            </div>
        </div>

        {
            entry.data.sections ? (
                <div class="flex flex-col gap-4">
                    {entry.data.sections.map((section) => (
                        <div class="border border-line hard-shadow">
                            <div class="flex flex-row border-b border-line items-center bg-secondary-bg">
                                <div class="font-mono font-bold text-xs px-2 py-2">
                                    {section.title}
                                </div>
                            </div>
                            <div class="columns-2 gap-0">
                                {section.photos.map((photo) => (
                                    <div class="break-inside-avoid">
                                        <Image
                                            src={photo.src}
                                            alt={photo.alt || ""}
                                            loading="lazy"
                                            class="w-full h-auto"
                                        />
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            ) : entry.data.photos ? (
                <div class="grid grid-cols-1 md:grid-cols-3 diagonal-lines border-l border-r border-b border-line bg-secondary-bg hard-shadow">
                    {entry.data.photos.map((photo) => (
                        <div class="aspect-square">
                            <Image
                                src={photo.src}
                                alt={photo.alt || ""}
                                loading="lazy"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    ))}
                </div>
            ) : null
        }
    </div>
</BaseLayout>
