---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDateRange } from "@utils/formatDateRange";

export async function getStaticPaths() {
    const photos = await getCollection("photos");
    return photos.map((photo) => ({
        params: { slug: photo.id },
        props: photo,
    }));
}

type Props = CollectionEntry<"photos">;
const entry = Astro.props;

const dateText = formatDateRange(
    entry.data.startDate,
    entry.data.endDate,
    entry.data.yearOnly,
);
---

<BaseLayout pageTitle={`Photos - ${entry.data.title}`}>
    <div
        class="flex flex-col md:flex-row w-full gap-2 items-start md:items-center"
    >
        <div class="flex flex-row grow items-center w-full gap-2">
            <h1 class="font-crimson italic text-3xl text-ink pt-2 md:pb-2 pr-2">
                {entry.data.title}
            </h1>
            <div class="grow border-b border-line"></div>
        </div>
        <div
            class="md:border md:border-line pb-4 md:pb-1 md:pt-1 md:px-2 font-mono text-xs text-ink-secondary whitespace-nowrap"
        >
            {dateText}
        </div>
    </div>
    <div class="font-crimson text-ink pb-6 md:pb-4 pt-2 w-full text-lg">
        {entry.data.description}
    </div>

    {
        entry.data.photos && (
            <div
                class={`w-full border border-line hard-shadow bg-secondary-bg diagonal-lines grid ${entry.data.photos.length < 3 ? "grid-cols-1" : "grid-cols-3"}`}
            >
                {entry.data.photos.map((p) => (
                    <div class="aspect-square overflow-hidden">
                        <Image
                            src={p.src}
                            alt={p.alt ?? ""}
                            class="w-full h-full object-cover hover:scale-105 duration-300 transition-all ease-in-out"
                        />
                    </div>
                ))}
            </div>
        )
    }

    {
        entry.data.sections && (
            <div class="w-full flex flex-col gap-4">
                {entry.data.sections.map((s) => (
                    <div class="w-full flex flex-col border border-line hard-shadow">
                        <div class="border-b border-line flex flex-row items-stretch">
                            <span class="italic font-crimson text-lg p-1">
                                {s.title}
                            </span>
                            {s.startDate && (
                                <div class="ml-auto border-l border-line px-2 text-xs font-mono text-ink-secondary whitespace-nowrap content-center">
                                    {formatDateRange(s.startDate, s.endDate)}
                                </div>
                            )}
                        </div>
                        <div
                            class={`bg-secondary-bg diagonal-lines grid w-full ${s.photos.length < 3 ? "grid-cols-1" : "grid-cols-3"}`}
                        >
                            {s.photos.map((p) => (
                                <div class="aspect-square overflow-hidden">
                                    <Image
                                        class="w-full h-full object-cover hover:scale-105 transition-all ease-in-out duration-300"
                                        src={p.src}
                                        alt={p.alt ?? ""}
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        )
    }
</BaseLayout>

<script>
    document.querySelectorAll<HTMLImageElement>("img").forEach((img) => {
        img.style.cursor = "pointer";
        img.addEventListener("click", () => window.open(img.src, "_blank"));
    });
</script>
