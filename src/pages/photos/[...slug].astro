---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const photos = await getCollection("photos");
    return photos.map((photo) => ({
        params: { slug: photo.id },
        props: photo,
    }));
}

type Props = CollectionEntry<"photos">;
const entry = Astro.props;

function formatFullDate(d: Date): string {
    return d.toLocaleDateString("en-US", {
        month: "long",
        day: "numeric",
        year: "numeric",
    });
}

const dateText = entry.data.endDate
    ? `${formatFullDate(entry.data.startDate)} - ${formatFullDate(entry.data.endDate)}`
    : formatFullDate(entry.data.startDate);
---

<BaseLayout pageTitle={`Photos - ${entry.data.title}`}>
    <div class="flex flex-row w-full gap-2 items-center">
        <h1 class="font-crimson italic text-3xl text-ink py-2 pr-2">
            {entry.data.title}
        </h1>
        <div class="grow border-b border-line"></div>
        <div class="border border-line py-1 px-2 font-mono text-xs text-ink">
            {dateText}
        </div>
    </div>
    <div class="font-crimson text-ink pb-4 pt-2 px-2 w-full text-lg">
        {entry.data.description}
    </div>

    {
        entry.data.photos && (
            <div class="w-full border border-line hard-shadow bg-secondary-bg diagonal-lines grid grid-cols-3">
                {entry.data.photos.map((p) => (
                    <div class="aspect-square overflow-hidden">
                        <Image
                            src={p.src}
                            alt={p.alt ?? ""}
                            class="w-full h-full object-cover hover:scale-105 duration-300 transition-all ease-in-out"
                        />
                    </div>
                ))}
            </div>
        )
    }

    {
        entry.data.sections && (
            <div class="w-full flex flex-col gap-4">
                {entry.data.sections.map((s) => (
                    <div class="w-full flex flex-col border border-line hard-shadow">
                        <div class="p-1 border-b border-line italic font-crimson text-lg">
                            {s.title}
                        </div>
                        <div class="bg-secondary-bg diagonal-lines grid grid-cols-3 w-full">
                            {s.photos.map((p) => (
                                <div class="aspect-square overflow-hidden">
                                    <Image
                                        class="w-full h-full object-cover hover:scale-105 transition-all ease-in-out duration-300"
                                        src={p.src}
                                        alt={p.alt ?? ""}
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        )
    }
</BaseLayout>

<script>
    document.querySelectorAll<HTMLImageElement>("img").forEach((img) => {
        img.style.cursor = "pointer";
        img.addEventListener("click", () => window.open(img.src, "_blank"));
    });
</script>
