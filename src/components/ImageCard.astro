---
/**
 * Simple card for displaying links to photos CollectionEntries.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Location from "~icons/carbon/location-filled";
interface Props {
    photos: CollectionEntry<"photos">;
}

const { photos } = Astro.props;

// TODO: bruh what even is this
function formatDate(d: Date): string {
    if (photos.data.yearOnly) return `${d.getUTCFullYear()}`;
    return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

function formatFullDate(d: Date): string {
    return d.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
    });
}

function formatDateRange(start: Date, end?: Date): string {
    if (end === undefined) {
        return formatDate(start);
    }

    if (start.getUTCFullYear() === end.getUTCFullYear()) {
        if (start.getUTCMonth() === end.getUTCMonth()) {
            return `${start.toLocaleDateString("en-US", { month: "short", day: "numeric" })} - ${formatFullDate(end)}`;
        }
        return `${start.toLocaleDateString("en-US", { month: "short", day: "numeric" })} - ${formatFullDate(end)}`;
    }

    return `${formatDate(start)} - ${formatDate(end)}`;
}

const displayDate = formatDateRange(photos.data.startDate, photos.data.endDate);
---

<a href={"/photos/" + photos.id}>
    <div
        class="group border border-line transition-all duration-150 hover:border-primary w-full hard-shadow hover:hard-shadow-hover relative hover:-translate-y-1 aspect-video"
    >
        <div
            class="inset-0 bg-linear-to-tr from-black/50 via-black/10 to-transparent absolute"
        >
        </div>
        <Image
            src={photos.data.cover}
            alt={photos.data.title + " cover"}
            class="object-cover w-full h-full"
        />
        <div
            class="absolute left-2 bottom-2 font-crimson text-white italic text-xl md:text-3xl text-shadow"
        >
            {photos.data.title}
        </div>
        <div
            class="absolute right-2 bottom-2 flex flex-row px-2 items-center border border-white text-xs text-white font-mono divide-x divide-white"
        >
            <div class="pr-2 py-1 flex flex-row gap-2 items-center">
                <Location class="h-4 w-4" />
                {photos.data.location}
            </div>
            <div class="text-shadow-hero pl-2 py-1">
                {displayDate}
            </div>
        </div>
    </div>
</a>
