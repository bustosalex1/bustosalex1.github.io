---
/**
 * A flexible grid of images with the same aspect ratio. If the images provided
 * do not have the same aspect ratio, they will be justified appropriately to
 * maintain an aspect ratio.
 */
import { Image } from "astro:assets";
import type { ImageTuple } from "@types";

interface Props {
    images: ImageTuple[];
    caption: string | undefined;
    rows: string;
    cols: string;
}

const { images, caption, rows, cols } = Astro.props;
---

<div>
    <div class={`grid ${cols} ${rows} gap-2 pb-2 overflow-clip`}>
        {
            images.map(([src, alt, caption], i) => (
                <div class="not-prose h-full w-full relative border border-line hard-shadow">
                    <Image
                        src={src}
                        alt={alt}
                        class="object-cover h-full w-full"
                    />
                    <div class="absolute left-0 right-0 bottom-0 border-t border-line-secondary bg-secondary-bg text-xs font-mono p-1 ">
                        {String.fromCharCode(97 + i)}. {caption}
                    </div>
                </div>
            ))
        }
    </div>
    {
        caption && (
            <figcaption class="border-l border-r border-b border-line hard-shadow">
                {caption}
            </figcaption>
        )
    }
</div>
