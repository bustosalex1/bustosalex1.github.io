{
    "name": "website",
    "type": "module",
    "version": "0.7",
    "packageManager": "pnpm@9.4.0",
    "scripts": {
        "sync": "astro sync",
        "stamp": "echo \"COMMIT_HASH=$(git rev-parse --short HEAD)\"> .env && echo \"WEBSITE_VERSION=$(node -p \"require('./package.json').version\")\">>.env",
        "dev": "astro dev",
        "start": "astro dev",
        "build": "pnpm stamp && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "format": "prettier . --write",
        "lint": "prettier --check . && eslint . && svelte-check --tsconfig ./tsconfig.json"
    },
    "dependencies": {
        "@fontsource/crimson-text": "^5.2.7",
        "@fontsource/fira-code": "^5.2.7",
        "@threlte/core": "^8.5.16",
        "@threlte/extras": "^9.21.0",
        "katex": "^0.16.47",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "@astrojs/markdown-remark": "^7.2.0",
        "@astrojs/mdx": "^5.0.6",
        "@astrojs/sitemap": "^3.7.3",
        "@astrojs/svelte": "^8.1.2",
        "@astrojs/ts-plugin": "^1.10.9",
        "@eslint/js": "^10.0.1",
        "@iconify-json/carbon": "^1.2.23",
        "@iconify-json/line-md": "^1.2.16",
        "@iconify-json/material-symbols": "^1.2.78",
        "@iconify-json/octicon": "^1.2.28",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.1",
        "@types/eslint": "^9.6.1",
        "@types/hast": "^3.0.4",
        "@types/three": "^0.184.1",
        "astro": "^6.4.8",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-svelte": "^3.5.2",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "sharp": "^0.34.5",
        "svelte": "^5.56.3",
        "svelte-check": "^4.6.0",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.1",
        "unist-util-visit": "^5.1.0",
        "unplugin-icons": "^23.0.1"
    },
    "overrides": {
        "vite": "^7"
    }
}
